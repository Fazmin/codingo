{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the Socratic Workspace window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "store:default",
    "shell:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://api.openai.com/*" },
        { "url": "https://api.anthropic.com/*" }
      ]
    }
  ]
}
